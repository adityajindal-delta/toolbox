{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "defaultMode": "auto"
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "printf '%s' '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"additionalContext\":\"Before committing: if code was written or edited in this change and /clean-comments has not yet been run on the changed files, run it now — strip AI-slop comments and keep only repo-style load-bearing comments.\"},\"systemMessage\":\"Reminder: run /clean-comments on changed files before commit.\"}'",
            "if": "Bash(git commit*)"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh /Users/adityajindal/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "chrome-devtools-mcp@chrome-devtools-plugins": true,
    "figma@claude-plugins-official": false,
    "compound-engineering@compound-engineering-plugin": true,
    "notion@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "deploy-change@anuj-skills": true,
    "warp@claude-code-warp": true,
    "standup@anuj-skills": true,
    "swift-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    },
    "compound-engineering-plugin": {
      "source": {
        "source": "github",
        "repo": "EveryInc/compound-engineering-plugin"
      }
    },
    "anuj-skills": {
      "source": {
        "source": "github",
        "repo": "anuj-delta/skills"
      }
    },
    "claude-code-warp": {
      "source": {
        "source": "github",
        "repo": "warpdotdev/claude-code-warp"
      }
    }
  },
  "effortLevel": "high",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipWorkflowUsageWarning": true,
  "theme": "auto",
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
